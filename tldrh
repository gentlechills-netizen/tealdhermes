#!/bin/bash
#
# tldrh — tldr for Hermes
# Affiche les pages d'aide des commandes Hermes en utilisant tealdeer.
#
# Usage:
#   tldrh            Lister les commandes Hermes disponibles
#   tldrh goal       Page d'aide de la commande /goal
#   tldrh --help     Cette aide

TLDRH_DIR="${TLDRH_DIR:-$HOME/.local/share/tldrh}"
CONFIG_DIR="$HOME/.config/tldrh"
LISTING="$HOME/.hermes/tldr-hermes/pages/_listing.md"

show_usage() {
    sed -n '/^# Usage:/,/^$/{s/^# //p}' "$0"
}

show_listing() {
    if [ -f "$LISTING" ]; then
        cat "$LISTING"
    else
        echo "Aucun listing trouvé. Exécute d'abord generate_listing.py"
        echo "ou configure TLDRH_DIR."
        exit 1
    fi
}

# --- Main ---

case "${1:-}" in
    --help|-h)
        show_usage
        exit 0
        ;;
    "")
        show_listing
        ;;
    *)
        TEALDEER_CONFIG_DIR="$CONFIG_DIR" tldr "$@"
        ;;
esac
