#!/bin/bash
#
# tldrh — tldr for Hermes
# Affiche les pages d'aide des commandes Hermes en utilisant tealdeer.
#
# Usage:
#   tldrh            Lister les commandes Hermes disponibles
#   tldrh goal       Page d'aide de la commande /goal
#   tldrh --help     Cette aide

TLDRH_DIR="${TLDRH_DIR:-$HOME/.local/share/tldrh}"
CONFIG_DIR="$HOME/.config/tldrh"
LISTING="$HOME/.hermes/tldr-hermes/pages/_listing.md"

show_usage() {
    sed -n '/^# Usage:/,/^$/{s/^# //p}' "$0"
}

show_listing() {
    if [ -f "$LISTING" ]; then
        cat "$LISTING"
    else
        echo "Aucun listing trouvé. Exécute d'abord generate_listing.py"
        echo "ou configure TLDRH_DIR."
        exit 1
    fi
}

# --- Main ---

case "${1:-}" in
    --help|-h)
        show_usage
        exit 0
        ;;
    "")
        show_listing
        ;;
    *)
        # Chercher la page dans le répertoire custom seulement
        PAGE_NAME="${1//\//-}"
        CUSTOM_PAGES=$(grep "^custom_pages_dir" "$CONFIG_DIR/config.toml" 2>/dev/null | cut -d= -f2 | tr -d ' "')
        CUSTOM_PAGES="${CUSTOM_PAGES/#\~/$HOME}"
        if [ -n "$CUSTOM_PAGES" ]; then
            FOUND=$(find "$CUSTOM_PAGES" -name "${PAGE_NAME}.page.md" -o -name "${PAGE_NAME}.md" 2>/dev/null | head -1)
            if [ -z "$FOUND" ]; then
                echo "❌ Page Hermes introuvable pour « $1 »"
                echo ""
                echo "  Commandes CLI : tldrhc <commande>  (ex: tldrhc chat)"
                echo "  Commandes TUI  : tldrh  <commande>  (ex: tldrh /model)"
                echo ""
                echo "  Voir la liste complète : tldrh"
                exit 1
            fi
        fi
        TEALDEER_CONFIG_DIR="$CONFIG_DIR" tldr "$@"
        ;;
esac
